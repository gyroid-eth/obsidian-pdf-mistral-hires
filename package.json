{
	"name": "obsidian-pdf-mistral-plugin",
	"version": "1.1.0",
	"description": "Convert PDFs to Markdown with Mistral OCR, extracting figures at high resolution. Fork of Mekann's pdf-mistral.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": ["obsidian", "pdf", "mistral", "ocr", "markdown"],
	"author": "gyroid",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"@mistralai/mistralai": "^1.5.1",
		"jimp": "^1.6.0",
		"pdfjs-dist": "3.11.174"
	},
	"overrides": {
		"zod": "3.25.76"
	}
}
